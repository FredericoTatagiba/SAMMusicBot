# ===== Discord =====
# Token do bot (https://discord.com/developers/applications -> Bot -> Reset Token)
DISCORD_TOKEN=

# Prefixo dos comandos (ex.: !play, !skip)
COMMAND_PREFIX='#'

# ===== Spotify =====
# Não precisa configurar nada: links do Spotify (faixa, álbum e playlist) são
# resolvidos sem credenciais (via página de embed pública). As variáveis abaixo
# são opcionais e atualmente ignoradas.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== Comportamento =====
# Tamanho máximo da fila por servidor
MAX_QUEUE_SIZE=200
# Tempo (ms) sem músicas na fila antes de sair do canal de voz (10000 = 10 s)
IDLE_DISCONNECT_MS=10000
# Tempo (ms) sozinho no canal (só o bot) antes de parar a reprodução (20000 = 20s)
EMPTY_CHANNEL_TIMEOUT_MS=20000
# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# ===== Segurança =====
# IDs dos servidores (guilds) autorizados a usar o bot, separados por vírgula.
# Vazio = sem restrição (qualquer servidor). Com IDs, o bot SÓ responde nesses
# servidores e SAI automaticamente de qualquer outro em que for adicionado.
# Como obter o ID: ative o Modo Desenvolvedor no Discord
# (Configurações > Avançado), clique com o botão direito no servidor > Copiar ID.
ALLOWED_GUILD_IDS=
